# =============================================================================
# Dream Look — Environment Variables
# -----------------------------------------------------------------------------
# This project is plain HTML/CSS/JS with NO build step, so these values are
# not read automatically from this file by the browser. Copy them into
# assets/js/config.js (or into Vercel's Environment Variables UI if you wire
# up a small build step later).
#
# Where to find these: Supabase Dashboard → Project Settings → API
# =============================================================================

# Project URL, e.g. https://abcdefghijk.supabase.co
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon / public key — safe to expose in client-side code; access is enforced
# by Row Level Security policies, not by hiding this key.
SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLIC-KEY

# service_role key — SERVER-SIDE ONLY. Never put this in config.js, never
# commit it, never ship it to the browser. Not used by this frontend at all.
# SUPABASE_SERVICE_ROLE_KEY=DO-NOT-EXPOSE-THIS-CLIENT-SIDE
